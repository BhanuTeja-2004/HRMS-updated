// Prisma schema — Smart HRMS
// Module 1: Employee Management
// Module 2: Attendance (worked hours), Payroll, Payslip

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id          Int       @id @default(autoincrement())
  employeeId  String    @unique
  name        String
  department  String?
  designation String?
  phone       String?
  email       String    @unique
  doj         DateTime?
  status      String    @default("Active")

  // Bank details
  accountHolder String?
  bankName      String?
  accountNumber String?
  ifsc          String?
  branch        String?
  panNumber     String?
  aadhaarNumber String?

  // CRM access
  crmEnabled Boolean @default(false)

  // Salary configuration (used to auto-generate payroll)
  monthlyCtc  Float?
  hourlyRate  Float?
  takeHome    Float?

  attendances Attendance[]
  payrolls    Payroll[]
  documents   EmployeeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model Attendance {
  id         Int       @id @default(autoincrement())
  employeeId Int
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date          DateTime
  loginAt       DateTime?
  logoutAt      DateTime?
  breakMinutes  Int      @default(0)
  workedMinutes Int      @default(0)
  status        String   @default("Present")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("attendance")
}

model Payroll {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month       String   // e.g. "2026-02"
  periodStart DateTime
  periodEnd   DateTime
  cycleDays   Int      @default(30)

  workedHours Float    @default(0)
  basic       Float    @default(0)
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  gross       Float    @default(0)
  net         Float    @default(0)
  bonus       Float    @default(0)

  status  String  @default("Draft") // Draft, Generated, Approved, Rejected
  remarks String?

  payslip Payslip?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("payroll")
}

model Payslip {
  id        Int     @id @default(autoincrement())
  payrollId Int     @unique
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  // Snapshot of employee details (auto-filled, editable before PDF)
  employeeName  String
  employeeCode  String
  designation   String?
  department    String?
  doj           DateTime?
  bankName      String?
  accountNumber String?
  ifsc          String?
  panNumber     String?
  aadhaarNumber String?

  month     String
  workedHours Float  @default(0)

  earnings   Json
  deductions Json
  grossPay   Float  @default(0)
  totalDeductions Float @default(0)
  netPay     Float  @default(0)

  invoiceDate DateTime?
  clauseDays  Int?

  status String @default("Draft") // Draft, Approved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payslip")
}

model Invoice {
  id            Int       @id @default(autoincrement())
  candidateRef  String    @unique // CRM / selected-candidate id
  candidateName String
  company       String?
  role          String?
  doj           DateTime?
  clauseDays    Int       @default(45)
  invoiceDate   DateTime?
  raised        Boolean   @default(false)
  raisedAt      DateTime?
  amount        Float?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoice")
}

model Reminder {
  id      Int       @id @default(autoincrement())
  type    String // Invoice, Payroll, Clause, Employee
  refId   String?
  title   String
  message String?
  dueDate DateTime?
  status  String    @default("Pending") // Pending, Done, Dismissed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reminder")
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  category String // Agreement, Offer Letter, Contract, Other
  fileName String
  fileType String?
  dataUrl  String  @db.LongText

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("employee_document")
}

model Vendor {
  id            Int      @id @default(autoincrement())
  company       String
  contactPerson String?
  website       String?
  location      String?
  clauseDays    Int      @default(45)

  documents VendorDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor")
}

model VendorDocument {
  id       Int    @id @default(autoincrement())
  vendorId Int
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  category String // Agreement, Other
  fileName String
  fileType String?
  dataUrl  String @db.LongText

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@map("vendor_document")
}

model Candidate {
  id            Int       @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  itType        String?   // IT, Non-IT
  qualification String?
  languages     Json?
  location      String?
  remarks       String?
  status        String    @default("New Lead")
  process       String?
  shortlisted   String    @default("No")
  interviewDate DateTime?
  doj           DateTime?
  owner         String?   // HR who added
  addedAt       DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("candidate")
}
